---
import { siteConfig, withBase } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const discordReady = Boolean(siteConfig.discordUrl);
---

<BaseLayout>
  <header class="site-header container">
    <a class="brand" href={withBase('/')} aria-label="IR Portugal home">
      <span class="brand__mark" aria-hidden="true">IR</span>
      <span>IR Portugal</span>
    </a>
    {
      discordReady && (
        <a
          class="site-header__link"
          href={siteConfig.discordUrl}
          target="_blank"
          rel="noreferrer"
        >
          Discord <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </header>

  <main id="main-content">
    <section class="hero container">
      <div class="hero__copy">
        <h1>Do your research.<br /><span>Work with others.</span></h1>
        <p class="hero__intro">
          IR Portugal is a small, informal Discord community for people doing
          independent work in AI, optimisation, algorithms and systems. Bring
          your own project, find people who can help, or offer guidance as a
          mentor.
        </p>
        {
          (discordReady || siteConfig.githubUrl) && (
            <div class="hero__actions">
              {discordReady && (
                <a
                  class="button"
                  href={siteConfig.discordUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Join the Discord <span aria-hidden="true">↗</span>
                </a>
              )}
              {siteConfig.githubUrl && (
                <a
                  class="plain-link"
                  href={siteConfig.githubUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  GitHub <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          )
        }
      </div>

      <div class="research-map" data-research-map>
        <div class="research-map__stage">
          <svg
            viewBox="0 0 100 100"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path data-link="collaborators" class="is-active" d="M50 32V19"
            ></path>
            <path data-link="mentors" d="M34 50H21"></path>
            <path data-link="feedback" d="M66 50h13"></path>
            <path data-link="share" d="M50 68v13"></path>
          </svg>
          <div class="research-map__core" aria-hidden="true">
            <svg viewBox="0 0 220 160">
              <g class="research-map__people">
                <path d="M34 62c-3-24 7-37 22-37 16 0 26 15 22 39"></path>
                <path d="M36 43c10-17 30-18 42 0"></path>
                <path d="M44 50c4-3 8-3 11 0m10 0c4-3 7-3 10 0"></path>
                <path d="M48 59c6 5 12 5 18 0"></path>
                <path d="M142 63c-3-24 7-38 22-38 16 0 26 15 22 39"></path>
                <path d="M144 43c10-17 30-18 42 0"></path>
                <path d="M152 50c4-3 8-3 11 0m10 0c4-3 7-3 10 0"></path>
                <path d="M156 59c6 5 12 5 18 0"></path>
                <path d="M34 69c-15 4-23 16-26 34m70-34c13 4 22 13 28 27"
                ></path>
                <path d="M142 69c-13 4-22 13-28 27m72-27c15 4 23 16 26 34"
                ></path>
                <path d="M75 77l27 30m44-30-24 28"></path>
                <path d="M18 137c60 5 125 5 184 0"></path>
                <path d="M72 103l76-6-9 29-77 7z"></path>
              </g>
              <g class="research-map__notes">
                <path d="M84 112c13-2 27-3 41-3m-45 12c17-1 34-3 50-5"></path>
                <path d="M108 88v-7m-9 4-4-5m22 5 4-5"></path>
              </g>
            </svg>
          </div>
          <button
            class="research-map__node research-map__node--top is-active"
            type="button"
            data-topic="collaborators"
            aria-pressed="true"
          >
            Collaborators
          </button>
          <button
            class="research-map__node research-map__node--left"
            type="button"
            data-topic="mentors"
            aria-pressed="false"
          >
            Mentors
          </button>
          <button
            class="research-map__node research-map__node--right"
            type="button"
            data-topic="feedback"
            aria-pressed="false"
          >
            Feedback
          </button>
          <button
            class="research-map__node research-map__node--bottom"
            type="button"
            data-topic="share"
            aria-pressed="false"
          >
            Share work
          </button>
        </div>
        <p class="research-map__answer" aria-live="polite">
          Find people who want to build with you.
        </p>
      </div>
    </section>

    <section class="idea container" aria-labelledby="idea-title">
      <div>
        <h2 id="idea-title">What independent research means.</h2>
      </div>
      <div class="idea__copy">
        <p>
          Independent research is work pursued outside a fixed programme: you
          choose the problem, set the direction, and decide what a useful result
          looks like.
        </p>
        <div class="idea__roles">
          <p>
            <strong>As a researcher</strong>
            <span
              >Bring a project, find collaborators and get honest feedback.</span
            >
          </p>
          <p>
            <strong>As a mentor</strong>
            <span>Find projects where your experience can be useful.</span>
          </p>
        </div>
      </div>
    </section>

    <section class="join-note container" aria-label="Discord community">
      <svg class="join-note__icon" viewBox="0 0 56 56" aria-hidden="true">
        <path d="M8 11h40v28H25L14 47l2-8H8z"></path>
        <circle cx="20" cy="25" r="2"></circle>
        <circle cx="28" cy="25" r="2"></circle>
        <circle cx="36" cy="25" r="2"></circle>
      </svg>
      <div>
        <h2>The community is on Discord.</h2>
        <p>Share a project, offer mentorship, or find someone to work with.</p>
      </div>
      {
        discordReady ? (
          <a
            class="button button--light"
            href={siteConfig.discordUrl}
            target="_blank"
            rel="noreferrer"
          >
            Open Discord <span aria-hidden="true">↗</span>
          </a>
        ) : (
          <span class="join-note__pending">Discord link coming soon</span>
        )
      }
    </section>
  </main>

  <footer class="site-footer container">
    <span>© {year} IR Portugal</span>
    {
      siteConfig.contactEmail && (
        <a href={`mailto:${siteConfig.contactEmail}`}>
          {siteConfig.contactEmail}
        </a>
      )
    }
  </footer>

  <script>
    const topicCopy = {
      collaborators: 'Find people who want to build with you.',
      mentors: 'As a mentor, find projects where your experience can help.',
      feedback: 'Test unfinished thinking with people who understand it.',
      share: 'Give useful work a place to be seen and discussed.',
    } as const;

    document
      .querySelectorAll<HTMLElement>('[data-research-map]')
      .forEach((map) => {
        const answer = map.querySelector<HTMLElement>('.research-map__answer');
        const buttons = map.querySelectorAll<HTMLButtonElement>('[data-topic]');
        const links = map.querySelectorAll<SVGPathElement>('[data-link]');

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const topic = button.dataset.topic as keyof typeof topicCopy;

            buttons.forEach((item) => {
              const selected = item === button;
              item.classList.toggle('is-active', selected);
              item.setAttribute('aria-pressed', String(selected));
            });
            links.forEach((link) => {
              link.classList.toggle('is-active', link.dataset.link === topic);
            });
            if (answer) answer.textContent = topicCopy[topic];
          });
        });
      });
  </script>
</BaseLayout>
