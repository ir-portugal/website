---
import { siteConfig, withBase } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const discordReady = Boolean(siteConfig.discordUrl);
---

<BaseLayout>
  <header class="site-header container">
    <a class="brand" href={withBase('/')} aria-label="IR Portugal home">
      <span class="brand__mark" aria-hidden="true">IR</span>
      <span>IR Portugal</span>
    </a>
    {
      discordReady && (
        <a
          class="site-header__link"
          href={siteConfig.discordUrl}
          target="_blank"
          rel="noreferrer"
        >
          Discord <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </header>

  <main id="main-content">
    <section class="hero container">
      <div class="hero__copy">
        <h1>Do your research.<br /><span>Work with others.</span></h1>
        <p class="hero__intro">
          IR Portugal is a small, informal Discord community for people doing
          independent work in AI, optimisation, algorithms and systems. Bring a
          project or an idea, meet people who can contribute, or join someone
          else's work with your experience.
        </p>
        {
          discordReady && (
            <div class="hero__actions">
              <a
                class="button"
                href={siteConfig.discordUrl}
                target="_blank"
                rel="noreferrer"
              >
                Join the Discord <span aria-hidden="true">↗</span>
              </a>
            </div>
          )
        }
      </div>

      <figure class="research-scene">
        <svg
          viewBox="0 0 560 500"
          role="img"
          aria-labelledby="research-scene-title research-scene-desc"
        >
          <title id="research-scene-title">
            People developing research together
          </title>
          <desc id="research-scene-desc">
            Three people exchange ideas around a table covered with notes while
            working through a problem on a large board.
          </desc>

          <path
            class="research-scene__wash"
            d="M39 104C87 35 199 5 293 30c104 28 195 118 219 221 22 95-10 190-110 220-91 28-235 9-312-59C16 346-6 171 39 104Z"
          ></path>
          <path
            class="research-scene__accent research-scene__orbit"
            d="M30 260C82 119 208 52 361 71c82 10 143 56 171 121"></path>

          <g class="research-scene__board">
            <path d="M70 48 493 39l5 213-426 8Z"></path>
            <path
              class="research-scene__tape"
              d="m101 34 62-4 3 30-63 4zM409 29l58 4-3 29-59-4z"></path>
            <g class="research-scene__ink">
              <path d="M107 111c23-37 50-36 75-3 21 28 42 29 64-3"></path>
              <path d="M108 149h139"></path>
              <path d="M284 90h64m-64 34h42m-42 34h78"></path>
              <path d="M387 89c33 8 56 28 67 58m-58 33c22-5 43-17 59-37"></path>
              <path d="m440 136 15 7-4-17"></path>
              <circle cx="387" cy="89" r="7"></circle>
              <circle cx="396" cy="180" r="7"></circle>
            </g>
            <g class="research-scene__accent research-scene__board-accent">
              <path d="m112 197 29-20 32 23 34-29 35 19"></path>
              <path d="M280 203c39-12 79-13 121-4"></path>
              <path d="m364 185 37 14-33 21"></path>
            </g>
          </g>

          <g class="research-scene__people research-scene__ink">
            <path d="M113 330c-4-35 10-57 36-57 28 0 43 24 37 59"></path>
            <path d="M116 295c17-27 50-28 70-2"></path>
            <path d="M128 305c5-4 10-4 15 0m20 0c5-4 10-4 14 0"></path>
            <path d="M138 319c10 8 20 8 29 0"></path>
            <path d="M95 397c3-38 20-58 47-65m45 1c20 7 36 25 43 50"></path>
            <path d="m179 350 60 55"></path>

            <path d="M373 330c-5-35 10-57 36-57 28 0 43 24 37 59"></path>
            <path d="M376 294c17-27 50-28 70-2"></path>
            <path d="M387 305c5-4 10-4 15 0m20 0c5-4 10-4 14 0"></path>
            <path d="M398 319c10 8 20 8 29 0"></path>
            <path d="M352 383c8-25 25-43 50-51m45 1c25 8 42 30 47 67"></path>
            <path d="m376 356-56 48"></path>

            <circle cx="278" cy="282" r="31"></circle>
            <path d="M250 273c15-25 42-28 60-6"></path>
            <path d="M260 282c5-3 9-3 13 0m13 0c5-3 9-3 13 0"></path>
            <path d="M268 294c8 6 16 6 23 0"></path>
            <path d="M244 391c0-43 9-69 27-79m15 0c20 11 31 38 32 80"></path>
            <path d="m254 330-47-49-41-43"></path>
            <path d="m160 244 6-6 8 2"></path>
          </g>

          <g class="research-scene__table research-scene__ink">
            <path d="M45 398c144-21 316-21 470 0l-18 71c-139 20-286 20-433 0Z"
            ></path>
            <path d="M64 469c143 17 286 17 433 0"></path>
            <path d="M88 486v-14m385 14v-14"></path>
            <path d="m151 393 72-13 18 33-76 10z"></path>
            <path d="m338 384 74 10-13 30-78-11z"></path>
            <path d="M255 404h51"></path>
            <path d="M262 417h38"></path>
            <circle cx="112" cy="418" r="14"></circle>
            <path d="M126 416c14-3 17 14 3 16"></path>
          </g>
          <g class="research-scene__accent research-scene__notes">
            <path d="M169 403c16-6 32-8 49-9"></path>
            <path d="M340 400c16 1 32 4 48 9"></path>
            <path d="M265 439c12-2 24-2 36 0"></path>
          </g>
        </svg>
      </figure>
    </section>

    <section class="idea container" aria-labelledby="idea-title">
      <div>
        <h2 id="idea-title">What independent research means.</h2>
      </div>
      <div class="idea__copy">
        <p>
          Independent research is work pursued outside a fixed programme: you
          choose the problem, set the direction, and decide what a useful result
          looks like.
        </p>
        <div class="idea__roles">
          <p>
            <strong>As a researcher</strong>
            <span
              >Bring a project or idea, find collaborators and get honest
              feedback.</span
            >
          </p>
          <p>
            <strong>As a mentor</strong>
            <span
              >Bring your own projects and questions, or help someone develop
              theirs.</span
            >
          </p>
        </div>
      </div>
    </section>

    <section class="join-note container" aria-label="Discord community">
      <svg class="join-note__icon" viewBox="0 0 56 56" aria-hidden="true">
        <path d="M8 11h40v28H25L14 47l2-8H8z"></path>
        <circle cx="20" cy="25" r="2"></circle>
        <circle cx="28" cy="25" r="2"></circle>
        <circle cx="36" cy="25" r="2"></circle>
      </svg>
      <div>
        <h2>The community is on Discord.</h2>
        <p>
          Bring a project or idea, offer mentorship, or find someone to work
          with.
        </p>
      </div>
      {
        discordReady ? (
          <a
            class="button button--light"
            href={siteConfig.discordUrl}
            target="_blank"
            rel="noreferrer"
          >
            Open Discord <span aria-hidden="true">↗</span>
          </a>
        ) : (
          <span class="join-note__pending">Discord link coming soon</span>
        )
      }
    </section>
  </main>

  <footer class="site-footer container">
    <span>© {year} IR Portugal</span>
    {
      siteConfig.contactEmail && (
        <a href={`mailto:${siteConfig.contactEmail}`}>
          {siteConfig.contactEmail}
        </a>
      )
    }
  </footer>
</BaseLayout>
